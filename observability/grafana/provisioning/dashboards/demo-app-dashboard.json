        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "loki",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Demo App — Overview",
  "uid": "demo-app-overview",
  "version": 1
